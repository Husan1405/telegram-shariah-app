# Telegram bot token — used ONLY by the bot/index.js launcher, not the frontend.
# Keep this secret. The token below is just a placeholder — rotate yours via @BotFather.
TELEGRAM_BOT_TOKEN=replace_me

# Public URL where the built Mini App is hosted (HTTPS required by Telegram).
# Examples: https://yourname.github.io/shariah, https://shariah.vercel.app
WEB_APP_URL=https://example.com
